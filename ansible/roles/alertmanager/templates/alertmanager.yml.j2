# TODO(taller): #7 — configuración de rutas + receptor de notificaciones
# Por defecto usa un webhook genérico. Para usar Slack, PagerDuty, email, etc.,
# reemplazar el bloque 'webhook_configs' con el receptor correspondiente.
# Referencia: https://prometheus.io/docs/alerting/latest/configuration/
global:
  resolve_timeout: 5m

route:
  group_by: ['alertname', 'instance', 'severity']
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
  receiver: 'webhook-notificaciones'
  routes:
    - match:
        severity: critical
      receiver: 'webhook-notificaciones'
      repeat_interval: 1h

receivers:
  # Receptor webhook genérico — envía JSON a cualquier endpoint HTTP.
  # Reemplazar la URL con el endpoint real del sistema de notificaciones.
  - name: 'webhook-notificaciones'
    webhook_configs:
      - url: '{{ alertmanager_webhook_url }}'
        send_resolved: true

inhibit_rules:
  - source_match:
      severity: critical
    target_match:
      severity: warning
    equal: ['alertname', 'instance']
